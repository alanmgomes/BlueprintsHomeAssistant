blueprint:
  name: Motion Lights (Mixed Sunset/Always-On)
  description: Control two sets of lights based on occupancy. Safely ignores blank inputs.
  domain: automation
  input:
    motion_entity:
      name: Occupancy Sensor
      selector:
        entity:
          domain: binary_sensor
          device_class: occupancy
    sunset_lights:
      name: Sunset-Only Lights
      description: These lights turn on only between sunset and sunrise.
      default: {}
      selector:
        target:
          entity:
            domain: light
    always_lights:
      name: Always-Active Lights
      description: These lights turn on every time motion is detected, 24/7.
      default: {}
      selector:
        target:
          entity:
            domain: light
    off_delay:
      name: Turn off delay
      default: 30
      selector:
        number:
          min: 0
          max: 3600
          unit_of_measurement: seconds
    sunset_offset:
      name: Sunset Offset
      description: "e.g., -00:30:00"
      default: "-00:30:00"
      selector:
        text:
    sunrise_offset:
      name: Sunrise Offset
      description: "e.g., -00:30:00"
      default: "-00:30:00"
      selector:
        text:

mode: restart

# Define variables so we can check if the inputs are empty
variables:
  always_target: !input always_lights
  sunset_target: !input sunset_lights

trigger:
  - platform: state
    entity_id: !input motion_entity
    from: "off"
    to: "on"
    id: detect
  - platform: state
    entity_id: !input motion_entity
    from: "on"
    to: "off"
    id: clear

action:
  - choose:
      # --- MOTION DETECTED ---
      - conditions:
          - condition: trigger
            id: detect
        sequence:
          # Only fire if Always-Active lights were selected
          - if:
              - condition: template
                value_template: "{{ always_target != {} and always_target != null }}"
            then:
              - action: light.turn_on
                target: !input always_lights
          
          # Only fire if Sunset lights were selected AND it is dark out
          - if:
              - condition: template
                value_template: "{{ sunset_target != {} and sunset_target != null }}"
              - condition: sun
                after: sunset
                after_offset: !input sunset_offset
                before: sunrise
                before_offset: !input sunrise_offset
            then:
              - action: light.turn_on
                target: !input sunset_lights

      # --- MOTION CLEARED ---
      - conditions:
          - condition: trigger
            id: clear
        sequence:
          - delay:
              seconds: !input off_delay
              
          # Safely turn off Always-Active lights if they exist
          - if:
              - condition: template
                value_template: "{{ always_target != {} and always_target != null }}"
            then:
              - action: light.turn_off
                target: !input always_lights
                
          # Safely turn off Sunset lights if they exist
          - if:
              - condition: template
                value_template: "{{ sunset_target != {} and sunset_target != null }}"
            then:
              - action: light.turn_off
                target: !input sunset_lights